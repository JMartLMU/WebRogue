object Player {
  name: string = "Mira";
  hp: number = 12;
}

object Key {
  name: string = "Rusty Key";
  hp: number = 0;
}

state Start {
  title: "Dungeon Entrance";
  description: "Cold air leaks from the stone archway.";
  contains: [Player, Key];
}

state Hall {
  title: "Long Hall";
  description: "The hallway bends into darkness.";
  contains: [Player];
}

_jump(Hall);
print "Two states are ready.";
