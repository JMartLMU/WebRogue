{
  "name": "webrogue",
  "version": "1.0.0",
  "description": "A small statically checked DSL for browser roguelike scripting.",
  "type": "module",
  "main": "src/webrogue.js",
  "bin": {
    "webrogue": "src/webrogue.js"
  },
  "scripts": {
    "test": "c8 node --test test/*.test.js",
    "coverage": "c8 node --test test/*.test.js",
    "compile": "node src/webrogue.js"
  },
  "keywords": [
    "compiler",
    "dsl",
    "roguelike",
    "ohm"
  ],
  "author": "Jacob Martinez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JMartLMU/WebRogue.git"
  },
  "homepage": "https://github.com/JMartLMU/WebRogue#readme",
  "dependencies": {
    "ohm-js": "^17.1.0"
  },
  "devDependencies": {
    "c8": "^10.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
